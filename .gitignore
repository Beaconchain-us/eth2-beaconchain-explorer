.env
.env.local
.env.*.local
config.toml
*.pem
*.key
# ==================== GENERAL ====================
csrfAuthKey: "0123456789abcdef0123456789abcdef"   # 32‑byte random hex key
jwtSigningSecret: "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef" # 64‑byte random hex key
jwtIssuer: "beaconcha.in"
jwtValidityInMinutes: 30

# ==================== SERVER ====================
server:
  host: "0.0.0.0"      # Listen on all network interfaces
  port: "3333"         # Desired port

# ==================== DATABASE ====================
database:
  user: "beacon_user"
  name: "beaconchain"
  host: "localhost"    # Use your PostgreSQL host
  port: "5432"
  password: "your_strong_db_password"

# ==================== SESSION SECURITY ====================
sessionSecret: "a_very_long_random_string_for_session_encryption"
flashSecret: ""        # Leave empty or use a random string

# ==================== EMAIL (SMTP) ====================
email:
  smtp:
    server: "smtp.gmail.com:587"
    host: "smtp.gmail.com"
    user: "your_email@gmail.com"
    password: "your_app_password"   # For Gmail, use an App Password

# ==================== BLOCKCHAIN API KEYS (for scanner) ====================
etherscanAPIKey: "YOUR_ETHERSCAN_API_KEY"
bscscanAPIKey: "YOUR_BSCSCAN_API_KEY"

# ==================== OTHER SETTINGS ====================
slotViz:
  enabled: false
  hardforkEpoch: 0